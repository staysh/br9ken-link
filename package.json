{
  "name": "br9ken-link",
  "version": "0.1.0",
  "private": true,
  "description": "RCS/MMS event flyer aggregator",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "flyer": "./dist/bin/flyer.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/src/index.js",
    "build": "npm run build:css && tsc -p tsconfig.json && npm run build:assets",
    "build:css": "tailwindcss -i src/assets/app.src.css -o src/public/app.css --minify",
    "build:assets": "node scripts/copy-assets.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "flyer": "tsx bin/flyer.ts"
  },
  "dependencies": {
    "@fastify/formbody": "^8.0.2",
    "@fastify/secure-session": "^8.3.0",
    "@fastify/static": "^9.1.1",
    "better-sqlite3": "^12.9.0",
    "commander": "^14.0.3",
    "drizzle-orm": "^0.45.2",
    "eta": "^4.5.1",
    "fastify": "^5.8.5",
    "libphonenumber-js": "^1.12.41",
    "nodemailer": "^8.0.5",
    "pino": "^10.3.1",
    "twilio": "^5.13.1",
    "ulid": "^3.0.2",
    "xmlbuilder2": "^4.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
