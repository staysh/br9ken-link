NODE_ENV=development
HOST=127.0.0.1
PORT=3000
PUBLIC_BASE_URL=https://flyer.example.com

# Display name and contact shown on the site and in the Privacy/Terms pages.
SITE_NAME=dinky.horse
CONTACT_EMAIL=staysh@br9ken.link

DATABASE_URL=./data/flyer.sqlite
# Path to the SpatiaLite loadable extension; on Debian install `libsqlite3-mod-spatialite`.
SPATIALITE_PATH=mod_spatialite
MEDIA_ROOT=./media

MESSAGING_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

MODERATOR_FANOUT=3

# Google Workspace SMTP for magic-link login; leave blank to disable mail until wired.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Flyer <no-reply@example.com>"

# 32+ random bytes (hex or base64); openssl rand -hex 32
SESSION_SECRET=change-me-to-at-least-32-bytes-of-random-data

SUBMIT_RATE_HOUR=5
SUBMIT_RATE_DAY=20
MEDIA_MAX_IMAGE_BYTES=20971520
MEDIA_MAX_VIDEO_BYTES=52428800
MEDIA_MAX_VIDEO_SECONDS=60

LOG_LEVEL=info
